{
  "name": "artclaw-creative-suite",
  "version": "1.1.0",
  "displayName": "ARTCLAW AI Creative Suite",
  "description": "通过 REST API 调用 ARTCLAW 平台的 AI 内容创作能力，支持 AI 生图、生视频、PPT 生成、工作流执行、多模态分析、Prompt 优化等能力。",
  "author": {
    "name": "ARTCLAW Team",
    "url": "https://artclaw.ai"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "image-generation",
    "video-generation",
    "ppt",
    "rest-api",
    "artclaw",
    "marketing",
    "creative",
    "生成图片",
    "生成视频",
    "AI绘画"
  ],
  "skill": "SKILL.md",
  "main": "__init__.py",
  "api": {
    "baseUrl": "http://43.156.26.92:8892/api/v1",
    "transport": "http",
    "endpoints": {
      "generate": {
        "image": { "method": "POST", "path": "/generate/image" },
        "video": { "method": "POST", "path": "/generate/video" },
        "marketing-image": { "method": "POST", "path": "/generate/marketing-image" },
        "product-carousel": { "method": "POST", "path": "/generate/product-carousel" },
        "ppt": { "method": "POST", "path": "/generate/ppt" }
      },
      "analyze": {
        "image": { "method": "POST", "path": "/analyze/image" },
        "video": { "method": "POST", "path": "/analyze/video" },
        "script": { "method": "POST", "path": "/analyze/script" },
        "characters": { "method": "POST", "path": "/analyze/characters" }
      },
      "workflows": {
        "list": { "method": "GET", "path": "/workflows" },
        "run": { "method": "POST", "path": "/workflows/{workflow_id}/run" }
      },
      "jobs": {
        "get": { "method": "GET", "path": "/jobs/{job_id}" },
        "list": { "method": "GET", "path": "/jobs" },
        "cancel": { "method": "POST", "path": "/jobs/{job_id}/cancel" }
      },
      "account": {
        "info": { "method": "GET", "path": "/account/info" }
      },
      "auth": {
        "verify": { "method": "POST", "path": "/auth/verify" }
      },
      "prompts": {
        "logo": { "method": "POST", "path": "/prompts/logo" },
        "cover": { "method": "POST", "path": "/prompts/cover" },
        "marketing": { "method": "POST", "path": "/prompts/marketing" },
        "carousel": { "method": "POST", "path": "/prompts/carousel" }
      }
    }
  },
  "auth": {
    "type": "apiKey",
    "headerName": "X-API-KEY",
    "paramLocation": "header",
    "prefix": "vk_",
    "required": true,
    "helpUrl": "https://staging.artclaw.com/#/settings",
    "helpText": "在 ARTCLAW 官网 Settings > API Keys 中创建，Key 以 vk_ 开头",
    "publicPaths": ["/api/v1/prompts/*", "/api/v1/auth/verify"]
  },
  "metadata": {
    "openclaw": {
      "emoji": "🎨",
      "requires": {
        "env": ["ARTCLAW_API_KEY"]
      },
      "primaryEnv": "ARTCLAW_API_KEY",
      "envMapping": {
        "ARTCLAW_API_KEY": "X-API-KEY"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArtClaw1/skills",
    "branch": "main"
  },
  "update": {
    "method": "tarball",
    "url": "https://github.com/ArtClaw1/skills/archive/refs/heads/main.tar.gz"
  },
  "install": {
    "steps": [
      "在 ARTCLAW 官网 https://staging.artclaw.com/#/settings 创建 API Key（以 vk_ 开头）",
      "在 HTTP 请求 Header 中添加 X-API-KEY: vk_your_key_here",
      "调用 REST API 端点 http://43.156.26.92:8892/api/v1/*"
    ]
  }
}
